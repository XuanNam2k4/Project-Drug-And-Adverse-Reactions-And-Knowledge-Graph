ex:Evidence_Patient_1000_lipitor_high_999 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.978_999 ;
    ex:sentenceText "was put on lipitor 3 months ago because of high cholesteral." ;
    ex:supportsRelation ex:Relation_Patient_1000_lipitor_high .

ex:Evidence_Patient_1001_lipitor_sore_1000 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.979_1000 ;
    ex:sentenceText "after being on lipitor for 2 years my knees and elbows were getting increasingly stiff and sore." ;
    ex:supportsRelation ex:Relation_Patient_1001_lipitor_sore .

ex:Evidence_Patient_1002_lipitor_stiff_1001 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.979_1001 ;
    ex:sentenceText "after being on lipitor for 2 years my knees and elbows were getting increasingly stiff and sore." ;
    ex:supportsRelation ex:Relation_Patient_1002_lipitor_stiff .

ex:Evidence_Patient_1003_lipitor_stiff_1002 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.979_1002 ;
    ex:sentenceText "i didn't make the connection to lipitor earlier because stiff, swollen joints were not listed as one of the side effects." ;
    ex:supportsRelation ex:Relation_Patient_1003_lipitor_stiff .

ex:Evidence_Patient_1004_lipitor_swollen_1003 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.979_1003 ;
    ex:sentenceText "i didn't make the connection to lipitor earlier because stiff, swollen joints were not listed as one of the side effects." ;
    ex:supportsRelation ex:Relation_Patient_1004_lipitor_swollen .

ex:Evidence_Patient_1005_lipitor_falls_1004 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.981_1004 ;
    ex:sentenceText "i began having falls shortly after starting lipitor approx 5years ago." ;
    ex:supportsRelation ex:Relation_Patient_1005_lipitor_falls .

ex:Evidence_Patient_1006_lipitor_frontal_lobe_abnormalities_1005 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.981_1005 ;
    ex:sentenceText "had another eeg 6months ago with frontal lobe abnormalities which i suspect is due to lipitor." ;
    ex:supportsRelation ex:Relation_Patient_1006_lipitor_frontal_lobe_abnormalities .

ex:Evidence_Patient_1007_lipitor_heart_attack_1006 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.984_1006 ;
    ex:sentenceText "as adiabetic you are at higher risk for stroke and heart attack so taking lipitor defininitely lowers the risk." ;
    ex:supportsRelation ex:Relation_Patient_1007_lipitor_heart_attack .

ex:Evidence_Patient_1008_lipitor_stroke_1007 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.984_1007 ;
    ex:sentenceText "as adiabetic you are at higher risk for stroke and heart attack so taking lipitor defininitely lowers the risk." ;
    ex:supportsRelation ex:Relation_Patient_1008_lipitor_stroke .

ex:Evidence_Patient_1009_lipitor_anxiety_1008 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.991_1008 ;
    ex:sentenceText "since i also have anxiety issues, i was not sure if lipitor caused side effects." ;
    ex:supportsRelation ex:Relation_Patient_1009_lipitor_anxiety .

ex:Evidence_Patient_100_norvasc_psychiatric_side_effects_99 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.106_99 ;
    ex:sentenceText "spoke to a psychiatrist and she confirmed that the entire family of norvasc called amlodiphine is known to have psychiatric side effects." ;
    ex:supportsRelation ex:Relation_Patient_100_norvasc_psychiatric_side_effects .

ex:Evidence_Patient_1010_liptor_memory_1009 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.991_1009 ;
    ex:sentenceText "stopped liptor and improved diet and memory improved." ;
    ex:supportsRelation ex:Relation_Patient_1010_liptor_memory .

ex:Evidence_Patient_1011_alpha_lipoic_acid_high_1010 a ex:Evidence ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.992_1010 ;
    ex:sentenceText "ive just stopped taking them,going to start high dose fish oil,coenzyme10,vit c and alpha lipoic acid and see what the next bloods say,please note other medicines were taken at the same time as the lipitor- ramipril and metoptolol andacid reducers for gout,so anybodies guess?." ;
    ex:supportsRelation ex:Relation_Patient_1011_alpha_lipoic_acid_high .

