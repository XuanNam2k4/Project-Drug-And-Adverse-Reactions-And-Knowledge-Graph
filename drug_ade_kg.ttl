ex:Post_LIPITOR.258 a ex:Post ;
    rdfs:label "LIPITOR.258" ;
    ex:extractedFromPost ex:Context_Patient_302_lipitor_could_not_walk,
        ex:Context_Patient_303_lipitor_pain,
        ex:Context_Patient_304_lipitor_ringing_in_my_ears,
        ex:Context_Patient_305_lipitor_sinus_problems,
        ex:Context_Patient_306_lipitor_hairloss,
        ex:Context_Patient_307_lipitor_lost_my_ability_to_walk ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.258_301,
        ex:Sentence_LIPITOR.258_302,
        ex:Sentence_LIPITOR.258_303,
        ex:Sentence_LIPITOR.258_304,
        ex:Sentence_LIPITOR.258_305,
        ex:Sentence_LIPITOR.258_306 ;
    ex:mentionsADE ex:ADE_could_not_walk,
        ex:ADE_hairloss,
        ex:ADE_lost_my_ability_to_walk,
        ex:ADE_pain,
        ex:ADE_ringing_in_my_ears,
        ex:ADE_sinus_problems ;
    ex:mentionsDrug ex:Drug_lipitor ;
    ex:postID "LIPITOR.258" ;
    ex:sentenceText "itook lipitor for ten plus years 10mg then doctor raised it to 20mg and about 2 weeks latter raised it to 40mg i took 4 pills and i could not walk,get out of a chair, put my hand up to my mouth,ringing in my ears, sinus problems,i was told the pain in my back was galblader when i had it removed 20years befor. itook lipitor for ten plus years 10mg then doctor raised it to 20mg and about 2 weeks latter raised it to 40mg i took 4 pills and i could not walk,get out of a chair, put my hand up to my mouth,ringing in my ears, sinus problems,i was told the pain in my back was galblader when i had it removed 20years befor. itook lipitor for ten plus years 10mg then doctor raised it to 20mg and about 2 weeks latter raised it to 40mg i took 4 pills and i could not walk,get out of a chair, put my hand up to my mouth,ringing in my ears, sinus problems,i was told the pain in my back was galblader when i had it removed 20years befor. itook lipitor for ten plus years 10mg then doctor raised it to 20mg and about 2 weeks latter raised it to 40mg i took 4 pills and i could not walk,get out of a chair, put my hand up to my mouth,ringing in my ears, sinus problems,i was told the pain in my back was galblader when i had it removed 20years befor. i ask my doctor about my hairloss and spots on my bodyandwas told your age wheni lost my ability to walk very far i ask my pharmacist what drug if any would cause this she said stop the lipitor and get to your doctor a.s.a.p. i ask my doctor about my hairloss and spots on my bodyandwas told your age wheni lost my ability to walk very far i ask my pharmacist what drug if any would cause this she said stop the lipitor and get to your doctor a.s.a.p."^^xsd:string .

