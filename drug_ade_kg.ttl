ex:Post_LIPITOR.506 a ex:Post ;
    rdfs:label "LIPITOR.506" ;
    ex:extractedFromPost ex:Context_Patient_570_coenzyme_q10_parkinsons,
        ex:Context_Patient_571_lipitor_parkinsons,
        ex:Context_Patient_572_lipitor_parkinsons ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.506_569,
        ex:Sentence_LIPITOR.506_570,
        ex:Sentence_LIPITOR.506_571 ;
    ex:mentionsADE ex:ADE_parkinsons ;
    ex:mentionsDrug ex:Drug_coenzyme_q10,
        ex:Drug_lipitor ;
    ex:postID "LIPITOR.506" ;
    ex:sentenceText "since lipitor causes a decrease in coenzyme q10 and now there is a study in the archives of neurology showing that using large doses of coenzyme q10 slows the progression of parkinson's disease, i wonder how many others have experienced a diagnosis of parkinson's having been on lipitor? since lipitor causes a decrease in coenzyme q10 and now there is a study in the archives of neurology showing that using large doses of coenzyme q10 slows the progression of parkinson's disease, i wonder how many others have experienced a diagnosis of parkinson's having been on lipitor? we began questioning the role of lipitor in parkinson's when my niece's husband who is 57 was experiencing the same symptoms as my husband the 57 yr old was diagnosed with parkinson's 2 weeks ago and the major factor in common between the 2 of them--lipitor for 4 yrs. not worth the risks of taking the drug."^^xsd:string .

