    ex:mentionsDrug ex:Drug_cq10,
        ex:Drug_lipitor,
        ex:Drug_statins ;
    ex:postID "LIPITOR.898" ;
    ex:sentenceText "no real heart problems - but weak heart muscle - likely cause of lipitor. also much fatigue then - and now. do not take statins - and if you do i hear the cq10 is a good protector for some of the muscle damage that the statins can cause. also much fatigue then - and now. do not take statins - and if you do i hear the cq10 is a good protector for some of the muscle damage that the statins can cause. also much fatigue then - and now. do not take statins - and if you do i hear the cq10 is a good protector for some of the muscle damage that the statins can cause. also much fatigue then - and now. do not take statins - and if you do i hear the cq10 is a good protector for some of the muscle damage that the statins can cause."^^xsd:string .

ex:Post_LIPITOR.926 a ex:Post ;
    rdfs:label "LIPITOR.926" ;
    ex:extractedFromPost ex:Context_Patient_963_lipitor_muscle_pain,
        ex:Context_Patient_964_lipitor_elevated_creatine,
        ex:Context_Patient_965_lipitor_discomfort,
        ex:Context_Patient_966_lipitor_heart_attack,
        ex:Context_Patient_967_lipitor_painful ;
    ex:mentionedInSentence ex:Sentence_LIPITOR.926_962,
        ex:Sentence_LIPITOR.926_963,
        ex:Sentence_LIPITOR.926_964,
        ex:Sentence_LIPITOR.926_965,
        ex:Sentence_LIPITOR.926_966 ;
    ex:mentionsADE ex:ADE_discomfort,
        ex:ADE_elevated_creatine,
        ex:ADE_heart_attack,
        ex:ADE_muscle_pain,
        ex:ADE_painful ;
    ex:mentionsDrug ex:Drug_lipitor ;
    ex:postID "LIPITOR.926" ;
    ex:sentenceText "i googled muscle pain and lipitor showed up on the first 6 or 7 entries!! so, i had blood tests done this week and have elevated creatine so was told today to stop lipitor immediately, and will see my doctor next week. after reading all these comments, i have no doubt that lipitor is the cause of all this discomfort. i'd rather die from a heart attack than die a slow painful death on lipitor. i'd rather die from a heart attack than die a slow painful death on lipitor."^^xsd:string .

ex:Post_ZIPSOR.5 a ex:Post ;
    rdfs:label "ZIPSOR.5" ;
    ex:extractedFromPost ex:Context_Patient_1058_zipsor_joint_pain,
        ex:Context_Patient_1059_zipsor_lupus,
        ex:Context_Patient_1060_zipsor_lupus,
